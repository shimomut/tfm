# Extra files to include in the source distribution (the wheel is governed by
# pyproject.toml's py-modules / packages / package-data). setuptools already
# ships tfm.py, the src/ package sources, README, LICENSE and pyproject.toml;
# the lines below add the end-user tools and prune everything not needed to
# install and run TFM.
include requirements.txt
recursive-include src/tools *

# Development trees and build byproducts — kept out of the sdist.
prune tools
prune temp
prune test
prune doc
prune build
prune macos_app
prune windows_app
prune .kiro
global-exclude __pycache__ *.py[cod] .DS_Store
