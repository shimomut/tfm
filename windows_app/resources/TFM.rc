/*
 * TFM.rc - resources compiled into TFM.exe (icon, manifest, version info).
 *
 * "version_generated.h" is written by build.ps1 (from $VERSION / tfm.py's
 * _VERSION) into the build's working directory alongside a copy of this .rc,
 * TFM.manifest, and TFM.ico, so all the relative includes below resolve there.
 */
#include <windows.h>
#include "version_generated.h"

/* Application manifest (RT_MANIFEST, id 1 = the process default manifest). */
1 RT_MANIFEST "TFM.manifest"

/* Application icon (id 1 = the icon Explorer shows for the .exe). */
1 ICON "TFM.ico"

VS_VERSION_INFO VERSIONINFO
 FILEVERSION    TFM_VER_MAJOR, TFM_VER_MINOR, TFM_VER_PATCH, TFM_VER_BUILD
 PRODUCTVERSION TFM_VER_MAJOR, TFM_VER_MINOR, TFM_VER_PATCH, TFM_VER_BUILD
 FILEFLAGSMASK  0x3fL
 FILEFLAGS      0x0L
 FILEOS         VOS_NT_WINDOWS32
 FILETYPE       VFT_APP
 FILESUBTYPE    VFT2_UNKNOWN
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904b0"   /* U.S. English, Unicode (1200) */
        BEGIN
            VALUE "CompanyName",      "TFM"
            VALUE "FileDescription",  "TFM - TUI File Manager"
            VALUE "FileVersion",      TFM_VER_STR
            VALUE "InternalName",     "TFM"
            VALUE "LegalCopyright",   "TFM contributors"
            VALUE "OriginalFilename", "TFM.exe"
            VALUE "ProductName",      "TFM"
            VALUE "ProductVersion",   TFM_VER_STR
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x409, 1200
    END
END
